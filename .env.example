PORT=3010

# MUST match SCHEDULER_SECRET in bbai-nestjs (preferred)
SCHEDULER_SECRET=bbai-scheduler-secret-change-me
# Legacy fallback if SCHEDULER_SECRET is unset
# NESTJS_INTERNAL_SECRET=

# Redis (BullMQ backend)
REDIS_URL=redis://localhost:6379

# AWS SQS — for CSV campaign execution
AWS_REGION=ap-south-1
CONTACT_IMPORT_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/ACCOUNT/bbai-contact-import-prod

# NestJS callback — for Broadcast campaign execution (path must match Nest setGlobalPrefix)
NESTJS_URL=http://localhost:3000/api/v1
