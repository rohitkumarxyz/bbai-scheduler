PORT=3010

# MUST match SCHEDULER_SECRET in bbai-nestjs
NESTJS_INTERNAL_SECRET=bbai-scheduler-secret-change-me

# Redis (BullMQ backend)
REDIS_URL=redis://localhost:6379

# AWS SQS — for CSV campaign execution
AWS_REGION=ap-south-1
CONTACT_IMPORT_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/ACCOUNT/bbai-contact-import-prod

# NestJS callback — for Broadcast campaign execution
NESTJS_URL=http://localhost:8080/api/v1
