{
  "name": "bbai-scheduler",
  "version": "1.0.0",
  "description": "BullMQ-based campaign scheduler — handles delayed CSV and Broadcast campaign execution",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "ts-node-dev --respawn src/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.600.0",
    "bullmq": "^5.12.0",
    "express": "^4.19.0",
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
